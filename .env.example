# Required: your Fireflies.ai API key.
# Get one from https://app.fireflies.ai/integrations/custom/fireflies
FIREFLIES_API_KEY=

# Optional: enables the `mine/` subtree (filtered to meetings you organized).
# If unset, the service will try to resolve it from the API at startup; if
# that also fails, the `mine/` directory is hidden.
FIREFLIES_USER_EMAIL=

# Optional: session JWT from the Fireflies web app. Used as a fallback when
# the public API's `transcripts` list query is broken (returns 500). Copy from
# browser devtools (Network tab, any request to app.fireflies.ai, authorization
# header). Expires every ~14 days; must be refreshed manually.
FIREFLIES_SESSION_TOKEN=
