# Required: your Fireflies.ai API key.
# Get one from https://app.fireflies.ai/integrations/custom/fireflies
FIREFLIES_API_KEY=

# Optional: enables the `mine/` subtree (filtered to meetings you organized).
# If unset, the service will try to resolve it from the API at startup; if
# that also fails, the `mine/` directory is hidden.
FIREFLIES_USER_EMAIL=

# Optional: Fireflies web-session access token used for the internal live
# transcript fallback. `fireflies-meetings auth-session` is the preferred way
# to keep this fresh; it writes ~/.config/fireflies-meetings/session.json and
# usually makes these env vars unnecessary.
FIREFLIES_SESSION_TOKEN=

# Optional: paired refresh token (`x-cache` cookie) for the internal web-app
# API. Improves the live-caption fallback for in-progress meetings.
FIREFLIES_REFRESH_TOKEN=

# Optional: internal auth provider label sent with the session tokens.
FIREFLIES_AUTH_PROVIDER=gauth

# Optional: browser/profile for the daemon's best-effort non-interactive
# session refresh from local Chrome/Chromium cookies at startup.
FIREFLIES_SESSION_BROWSER=chrome
FIREFLIES_SESSION_PROFILE=Default
